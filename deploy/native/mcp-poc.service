[Unit]
Description=imcp2 MCP server (mcp-poc)
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=ec2-user
WorkingDirectory=/opt/imcp2
Environment=PORT=8000
Environment=PUBLIC_URL=__PUBLIC_URL__
Environment=RUST_LOG=info
# Dynamic client registrations persist here so OAuth clients that cached their
# client_id keep working across redeploys. StateDirectory (=/var/lib/imcp2) is
# created service-owned and survives restarts; /opt/imcp2 is replaced each deploy.
StateDirectory=imcp2
Environment=OAUTH_CLIENTS_FILE=%S/imcp2/oauth-clients.json
ExecStart=/opt/imcp2/mcp-poc
Restart=always
RestartSec=3
LimitNOFILE=65536

[Install]
WantedBy=multi-user.target
